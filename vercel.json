{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/:path((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/relay.js": { "maxDuration": 10 },
    "api/nonce.js": { "maxDuration": 10 }
  }
}
